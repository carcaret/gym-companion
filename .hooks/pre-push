#!/usr/bin/env bash
# pre-push hook: incrementa el PATCH de APP_VERSION en app.js y crea un commit.
# Se activa con: git config core.hooksPath .hooks

set -e

APP_JS="app.js"

# Leer versión actual
current=$(sed -n "s/.*APP_VERSION = '\([0-9.]*\)'.*/\1/p" "$APP_JS")
if [ -z "$current" ]; then
  echo "pre-push: no se encontró APP_VERSION en $APP_JS, saltando bump." >&2
  exit 0
fi

# Separar en major.minor.patch
IFS='.' read -r major minor patch <<< "$current"
patch=$((patch + 1))
new_version="${major}.${minor}.${patch}"

# Actualizar app.js
tmp=$(mktemp) && sed "s/APP_VERSION = '${current}'/APP_VERSION = '${new_version}'/" "$APP_JS" > "$tmp" && mv "$tmp" "$APP_JS"

# Commit automático del bump
git add "$APP_JS"
git commit -m "chore: bump version ${current} → ${new_version}"

echo "pre-push: versión actualizada ${current} → ${new_version}"
